# ─────────────────────────────────────────────────────────────────────────────
# ZenithStore Infra — variabili d'ambiente
# ─────────────────────────────────────────────────────────────────────────────
# Copia questo file in .env e sostituisci i valori placeholder con i segreti reali.
# Il file .env NON deve mai essere committato nel repository.
#
# Come funziona:
#   • I comandi docker compose eseguiti dalla root del repo infra leggono .env
#     automaticamente (Docker Compose Spec). Nessun export manuale necessario.
#   • I comandi docker build (repo app) richiedono di caricare le variabili
#     manualmente: set -a && source <path>/.env && set +a
#
# Variabili usate da:
#   docker/compose.db.yml         → DB_PASSWORD, MONGO_PASSWORD (+ opzionali DB/Mongo)
#   docker/compose.blue.yml       → tutti i gruppi qui sotto tranne Monitoring
#   docker/compose.green.yml      → stesse variabili di blue
#   docker/compose.monitoring.yml → GRAFANA_PASSWORD
# ─────────────────────────────────────────────────────────────────────────────

# ── Segreti (OBBLIGATORI — sostituire prima del primo avvio) ──────────────────

# Password root di MySQL.
# Usata da: compose.db.yml (MYSQL_ROOT_PASSWORD) e compose.blue/green.yml (DB_PASSWORD).
DB_PASSWORD=change-me-strong-db-password

# Password admin di MongoDB.
# Usata da: compose.db.yml (MONGO_INITDB_ROOT_PASSWORD) e compose.blue/green.yml (MONGODB_URI).
MONGO_PASSWORD=change-me-strong-mongo-password

# Chiave segreta per la firma dei JWT (minimo 32 caratteri).
JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars

# Segreto per NextAuth.js — generare con: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-random-secret-min-32-chars-for-nextauth

# ── URL Applicazione ──────────────────────────────────────────────────────────

# URL pubblico dell'applicazione, con schema.
# Controlla: NEXTAUTH_URL, NEXT_PUBLIC_BACKEND_URL e il build-arg del frontend.
# Esempi: http://localhost  |  https://zenithstore.com  |  http://192.168.1.10
APP_URL=http://localhost

# URL WebSocket del backend (stesso host di APP_URL, schema ws:// o wss://).
# Esempio produzione: wss://zenithstore.com
NEXT_PUBLIC_WS_URL=ws://localhost

# ── Deployment ────────────────────────────────────────────────────────────────

# Tag dell'immagine Docker da deployare (es. git commit SHA, "latest").
IMAGE_TAG=latest

# ── Database MySQL (avanzato — modificare solo se si usa un DB esterno) ───────

# DB_HOST=mysql             # hostname del container MySQL sulla rete Docker
# DB_PORT=3306              # porta container
# DB_USERNAME=root          # utente MySQL
# DB_DATABASE=zenithstore   # nome del database

# ── Database MongoDB (avanzato — modificare solo con DB esterno) ──────────────

# MONGO_HOST=mongodb        # hostname del container MongoDB sulla rete Docker
# MONGO_PORT=27017          # porta container
# MONGO_USERNAME=admin      # utente admin
# MONGO_DATABASE=zenithstore

# ── Dominio e CORS ────────────────────────────────────────────────────────────

# Solo il hostname (senza schema), usato come ALLOWED_DOMAIN nel backend.
# Esempi: localhost  |  zenithstore.com  |  192.168.1.10
APP_DOMAIN=localhost

# Override delle origini CORS consentite (lista separata da virgola).
# Default stack blue:  http://localhost,http://localhost:3000,http://localhost:3001
# Default stack green: http://localhost,http://localhost:3010,http://localhost:3011
# In produzione impostare solo il dominio pubblico:
# CORS_ORIGIN=https://zenithstore.com

# ── JWT / Auth ────────────────────────────────────────────────────────────────

# Durata dei token JWT (es. 9h, 1d, 7d).
# JWT_EXPIRES_IN=9h

# Durata della sessione NextAuth in ore.
# AUTH_SESSION_MAX_AGE_HOURS=9

# ── OAuth (Google) ────────────────────────────────────────────────────────────

# In sviluppo si usano i mock values; in produzione inserire le credenziali reali
# dal Google Cloud Console (https://console.cloud.google.com).
GOOGLE_CLIENT_ID=mock-google-client-id
GOOGLE_CLIENT_SECRET=mock-google-client-secret

# ── Frontend build / runtime ──────────────────────────────────────────────────

# Abilita il pulsante "Simula Pagamento" nel checkout.
# Impostare a false solo in caso di integrazione con un reale payment provider.
# NEXT_PUBLIC_MOCK_PAYMENT=true

# Log di debug nel frontend (browser console).
# NEXT_PUBLIC_DEBUG_LOGS=false
# NEXT_PUBLIC_INFO_LOGS=true

# ── Cart / Job settings ───────────────────────────────────────────────────────

# CART_EXPIRATION_HOURS=24
# RESERVED_EXPIRATION_HOURS=3
# CART_CLEANUP_INTERVAL_MINUTES=10
# CART_GRACE_PERIOD_MINUTES=15

# ── Rate Limiting ─────────────────────────────────────────────────────────────

# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=1000

# ── Deploy / Rollback ─────────────────────────────────────────────────────────

# Secondi di finestra rollback dopo uno switch Blue-Green.
# In questo intervallo il vecchio stack rimane attivo per un eventuale rollback.
# ROLLBACK_WINDOW_SECONDS=300

# ── Monitoring ────────────────────────────────────────────────────────────────

# Password admin di Grafana (default se non impostata: admin — cambiare in produzione).
# GRAFANA_PASSWORD=change-me-grafana-password

# ── Alertmanager SMTP ─────────────────────────────────────────────────────────
# Configurazione del server SMTP usato da Alertmanager per inviare le notifiche email.
# Tutti i valori vengono iniettati come variabili d'ambiente nel container Alertmanager
# ed espansi nel file alertmanager.yml tramite il flag --config.expand-env.

# Indirizzo e porta SMTP (es. smtp.gmail.com:587, smtp.sendgrid.net:587).
SMTP_HOST=smtp.example.com:587

# Indirizzo mittente delle email di alert.
SMTP_FROM=alertmanager@zenithstore.com

# Username per l'autenticazione SMTP (spesso uguale a SMTP_FROM).
SMTP_USERNAME=alertmanager@zenithstore.com

# Password SMTP. Non committare mai il valore reale.
SMTP_PASSWORD=change-me-smtp-password

# Indirizzo email destinatario delle notifiche di alert.
ALERT_EMAIL_TO=team@zenithstore.com

# ─────────────────────────────────────────────────────────────────────────────
# Jenkins Global properties
# ─────────────────────────────────────────────────────────────────────────────
# Queste variabili NON vanno nel file .env (non sono lette da Docker Compose).
# Si configurano in: Manage Jenkins → Configure System → Global properties
#                    → Environment variables → Aggiungi
#
# Una volta impostate in Jenkins, sono disponibili come env.VAR_NAME
# nel Jenkinsfile e usate con il pattern "${env.VAR ?: 'default'}".
# ─────────────────────────────────────────────────────────────────────────────
#
# APP_REPO
#   URL del repository app clonato dalla pipeline.
#   Default nel Jenkinsfile: https://github.com/albertogelmi/profession-ai-web-development-zenithstore-app.git
#   Esempio produzione:       https://github.com/my-org/zenithstore-app.git
#
# NOTIFICATION_EMAIL
#   Email destinatario delle notifiche di build Jenkins (successo/fallimento).
#   Default nel Jenkinsfile: team@zenithstore.com
#
# NEXT_PUBLIC_BACKEND_URL
#   URL pubblico del backend — usato come build-arg nel docker build del frontend.
#   Default nel Jenkinsfile: http://localhost
#   Esempio produzione:       https://zenithstore.com
#
# NEXT_PUBLIC_WS_URL
#   URL WebSocket pubblico — usato come build-arg nel docker build del frontend.
#   Default nel Jenkinsfile: ws://localhost
#   Esempio produzione:       wss://zenithstore.com
#
# NEXT_PUBLIC_MOCK_PAYMENT
#   Abilita il pulsante "Simula Pagamento" nel checkout.
#   Default nel Jenkinsfile: true
#   Produzione con payment provider reale: false
